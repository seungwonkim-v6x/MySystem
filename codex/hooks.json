{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.codex/hooks/dangerous-command-blocker.py\""},
          {"type": "command", "command": "python3 \"$HOME/.codex/hooks/secret-scanner.py\""},
          {"type": "command", "command": "bash \"$HOME/.codex/hooks/block-dangerous-git.sh\""}
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python3 \"$HOME/.codex/hooks/env-file-protection.py\""}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "bash \"$HOME/.codex/hooks/render-md.sh\""}
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "\"$HOME/.codex/hooks/update-skills.sh\""}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "bash \"$HOME/.codex/hooks/preview-stop.sh\""}
        ]
      }
    ]
  }
}
