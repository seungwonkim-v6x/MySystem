# Pre-commit config — MySystem template
#
# Goal: catch what /review (LLM) shouldn't waste tokens on:
# secrets, lint, format, simple SAST patterns. <5s total runtime target.
#
# Install:  pip install pre-commit && pre-commit install
# Run all:  pre-commit run --all-files
# Update:   pre-commit autoupdate
#
# After this is wired, /review can focus on trust boundaries, SQL safety,
# conditional side effects, and other things hooks can't catch.

repos:
  # Universal hygiene — fast, language-agnostic
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-yaml
      - id: check-json
      - id: check-added-large-files
        args: ['--maxkb=500']
      - id: check-merge-conflict
      - id: detect-private-key

  # Secrets scan — must come first; cheaper than humans finding secrets in git history
  - repo: https://github.com/gitleaks/gitleaks
    rev: v8.21.0
    hooks:
      - id: gitleaks

  # Static analysis — semgrep with curated low-noise registry rules
  - repo: https://github.com/semgrep/pre-commit
    rev: v1.95.0
    hooks:
      - id: semgrep
        args:
          - --config=p/security-audit
          - --config=p/secrets
          - --error
          - --quiet
          - --skip-unknown-extensions

  # Lint + format — keep one section per language; remove the ones you don't use
  # ── TypeScript / JavaScript ────────────────────────────────────────────
  - repo: https://github.com/oxc-project/mirrors-oxlint
    rev: v0.13.0
    hooks:
      - id: oxlint
        args: ['--deny=correctness']

  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v4.0.0-alpha.8
    hooks:
      - id: prettier
        types_or: [javascript, jsx, ts, tsx, css, scss, json, yaml, markdown]

  # ── Python ─────────────────────────────────────────────────────────────
  # Uncomment when working in Python repos:
  # - repo: https://github.com/astral-sh/ruff-pre-commit
  #   rev: v0.7.0
  #   hooks:
  #     - id: ruff
  #       args: [--fix, --exit-non-zero-on-fix]
  #     - id: ruff-format

  # ── Rust ───────────────────────────────────────────────────────────────
  # Uncomment when working in Rust repos:
  # - repo: https://github.com/doublify/pre-commit-rust
  #   rev: v1.0
  #   hooks:
  #     - id: fmt
  #     - id: clippy
  #       args: [--, -D, warnings]

# Performance budget: pre-commit run --all-files should finish under 5s on a small
# diff. If it's slower, prune semgrep rule packs first (they're the usual culprit).
