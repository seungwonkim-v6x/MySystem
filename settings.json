{
  "permissions": {
    "allow": [
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Read(//private/tmp/**)",
      "Bash(pnpm run:*)",
      "Bash(git submodule:*)",
      "Bash(python3 -c ':*)",
      "Bash(~/.claude/skills/gstack/bin/gstack-review-read)",
      "mcp__notion__notion-fetch",
      "mcp__claude_ai_Slack__slack_read_thread",
      "mcp__mempalace__mempalace_search",
      "mcp__mempalace__mempalace_kg_query",
      "Bash(npx oxlint:*)",
      "Bash(echo '')",
      "Bash(echo '# Claude Code daily update')",
      "Bash(echo 'alias cc-update=\"claude update && claude changelog\"')",
      "Skill(qa-only)",
      "Skill(qa-only:*)",
      "Bash(psql -h localhost -p 54322 -U postgres -d postgres -c ':*)",
      "Bash(npx supabase:*)"
    ],
    "additionalDirectories": [
      "/Users/seungwonkim/.claude"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mempalace-wake-up.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/submodule-auto-update.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mempalace-auto-mine.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "coderabbit@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "effortLevel": "high"
}
