  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/update-skills.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/dangerous-command-blocker.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/secret-scanner.py"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/env-file-protection.py"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/preview-stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ] && [ -r '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ] && [ -x '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh' ]; then /bin/sh '/Users/seungwonkim/.orca/agent-hooks/claude-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/render-md.sh"
          }
        ]
      },
      {
        "matcher": "*",
